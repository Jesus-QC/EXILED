{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**/*.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "dest": "output",
      "filter": "docs/filterConfig.yml"
    }
  ],
  "build": {
    "template":["default","templates/singulinkfx"],
    "content": [
      {
        "src": "obj/docs/",
        "files": ["**/*.yml"]
      },
      {
        "src": "docs",
        "files": ["**/*.md"]
      },
      {
        "files": ["toc.yml", "docs/articles/toc.yml"]
      }
    ],
    "resource": [
      {
        "files": ["assets/**"]
      }
    ],
    "globalMetadata": {
      "_appTitle": "EXILED",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/Exiled-Official/EXILED",
        "branch": "dev"
      },
      "_appLogoPath": "assets/Exiled_Icon_50x50.png",
      "_appFaviconPath": "assets/Exiled_Icon.ico"
    }
  }
}
