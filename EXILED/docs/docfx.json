{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**/*.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ],
          "src": "../"
        }
      ],
      "filter": "docs/filterConfig.yml"
    }
  ],
  "build": {
     "globalMetadata": {
      "_appTitle": "EXILED",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/Exiled-Official/EXILED",
        "branch": "dev"
      },
    }
    "template": ["default", "templates/singulinkfx"],
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md",
          "toc.yml",
          "*.md".
        ]
      },
      {
        "files": [
          "articles/**.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "assets/**"
        ]
      }
    ],
    "dest": "_site",
  }
}
